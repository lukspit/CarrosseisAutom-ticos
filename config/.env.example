# Credenciais de Imagem (Opcional, mas recomendado para alta qualidade)
# Como obter: Crie conta na fal.ai, adicione $10 de crédito, gere uma API Key
# Se deixar em branco, o sistema usará um gerador 100% gratuito (porém de menor qualidade).
FAL_KEY=sua_chave_aqui

# Credenciais do Telegram
# Copie este arquivo para config/.env e preencha com seus dados.
# O arquivo .env é ignorado pelo git — suas credenciais ficam apenas locais.
#
# Como obter:
#   TELEGRAM_TOKEN: crie um bot com @BotFather no Telegram
#   TELEGRAM_CHAT_ID: envie uma mensagem para o bot e use /getUpdates para ver o chat_id
#
# O comando /chef guia você por todo esse processo automaticamente.

TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui
